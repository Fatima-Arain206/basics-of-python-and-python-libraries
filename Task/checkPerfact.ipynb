   ],
   "source": [
    "sq = int(input(\"enter a number\"))\n",
    "notsq = False\n",
    "n=0\n",
    "for i in range(1,sq):\n",
    "    if i*i == sq:\n",
    "        notsq = True\n",
    "        n=i\n",
    "        break\n",
    "    \n",
    "if notsq:\n",
    "    print(n,\" is perfect  square \")   \n",
    "else:\n",
    "    print(\"Not a perfect sq\")           \n",
    "    \n"
   ]
  }
