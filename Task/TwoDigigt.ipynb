   "source": [
    "number = int(input(\"Enter a number \"))\n",
    "count = 0\n",
    "if number == 0:\n",
    "      count =1\n",
    "\n",
    "while number> 0:\n",
    "      count+=1\n",
    "      number = number // 10\n",
    "     \n",
    "print(f\"total digits {count}\")\n"
   ]
