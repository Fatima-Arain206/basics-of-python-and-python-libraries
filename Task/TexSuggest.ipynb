   "source": [
    "salary = int(input(\"Enter your monthly salary \"))\n",
    "if salary < 50000:\n",
    "    print(\"0% tex\")\n",
    "elif salary >= 50000 and salary <= 100000:\n",
    "    print(\"10 % tex\")    \n",
    "else:\n",
    "   per=  salary*20/100  \n",
    "   print(f\" {per }% tex\")  \n"
   ]
  }
